+++ b/data/teoria.js
@@ -820,5 +820,19 @@ spam, phishing, ataques DDoS desde IPs de AWS, malware.
 - Infraestructura segura con modelo de responsabilidad compartida.`
       }
     ]
+  },
+  {
+    tema: "Glosario de Iconos Analizados",
